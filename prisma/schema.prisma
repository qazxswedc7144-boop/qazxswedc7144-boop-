// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  binaryTargets   = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

enum UserRole {
  PLATFORM_OWNER
  TENANT_ADMIN
  ADMIN
  ACCOUNTANT
  PHARMACIST
  CASHIER
  AUDITOR
  INVENTORY_MANAGER
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  POST_JOURNAL
  USER_REGISTER
  USER_LOGIN
}

enum Role {
  PLATFORM_OWNER
  TENANT_ADMIN
  ADMIN
  ACCOUNTANT
  PHARMACIST
  CASHIER
  AUDITOR
  INVENTORY_MANAGER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum InvoiceType {
  SALE
  PURCHASE
  RETURN_SALE
  RETURN_PURCHASE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIALLY_PAID
}

enum DocumentStatus {
  ACTIVE
  POSTED
  ARCHIVED
  LOCKED
}

enum MovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER
  RETURN
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  passwordHash String
  role         Role           @default(CASHIER)
  isActive     Boolean        @default(true)
  version      Int            @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  auditLogs    AuditLog[]
  sessions     Session[]
  refreshTokens RefreshToken[]
  branchUsers  BranchUser[]
  tenantUsers  TenantUser[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Permission {
  id        String   @id @default(uuid())
  role      Role
  action    String // "READ", "WRITE", "DELETE", "POST_JOURNAL"
  resource  String // "INVOICES", "ACCOUNTS", "INVENTORY"
  createdAt DateTime @default(now())

  @@unique([role, action, resource])
  @@map("permissions")
}

model Account {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  type         AccountType
  parentId     String?
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Account[]     @relation("AccountHierarchy")
  isSystem     Boolean       @default(false)
  balance      Decimal       @default(0.00) @db.Decimal(18, 4)
  version      Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  journalLines JournalLine[]
  tenantId     String?
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("accounts")
}

model JournalEntry {
  id          String        @id @default(uuid())
  date        DateTime      @default(now())
  sourceId    String? // e.g. Link to Invoice ID
  sourceType  String? // "INVOICE", "VOUCHER", "MANUAL"
  referenceId String? // Invoice/receipt reference number
  status      String        @default("DRAFT") // DRAFT, POSTED, REVERSED
  description String?
  debitTotal  Decimal       @default(0.00) @db.Decimal(18, 4)
  creditTotal Decimal       @default(0.00) @db.Decimal(18, 4)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       JournalLine[]
  branchId    String?
  tenantId    String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([sourceId, sourceType])
  @@index([date])
  @@index([branchId])
  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(uuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit       Decimal      @default(0.00) @db.Decimal(18, 4)
  credit      Decimal      @default(0.00) @db.Decimal(18, 4)
  description String?
  createdAt   DateTime     @default(now())

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

model Product {
  id                 String              @id @default(uuid())
  name               String
  barcode            String?             @unique
  sku                String?             @unique
  description        String?
  price              Decimal             @default(0.00) @db.Decimal(18, 4)
  cost               Decimal             @default(0.00) @db.Decimal(18, 4)
  stockQuantity      Int                 @default(0)
  version            Int                 @default(0)
  isSystem           Boolean             @default(false)
  isActive           Boolean             @default(true)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  invoiceItems       InvoiceItem[]
  inventoryBatches   InventoryBatch[]
  inventoryMovements InventoryMovement[]
  reservations       Reservation[]
  tenantId           String?
  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@index([createdAt])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  balance   Decimal  @default(0.00) @db.Decimal(18, 4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  balance   Decimal  @default(0.00) @db.Decimal(18, 4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

model Invoice {
  id             String         @id @default(uuid())
  invoiceNumber  String         @unique
  date           DateTime       @default(now())
  type           InvoiceType
  partnerId      String? // References Customer or Supplier uuid
  partnerType    String? // "CUSTOMER" or "SUPPLIER"
  totalAmount    Decimal        @default(0.00) @db.Decimal(18, 4)
  status         InvoiceStatus  @default(DRAFT)
  paymentStatus  PaymentStatus  @default(UNPAID)
  documentStatus DocumentStatus @default(ACTIVE)
  isSynced       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          InvoiceItem[]
  branchId       String?
  tenantId       String?
  tenant         Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([partnerId])
  @@index([createdAt])
  @@index([branchId])
  @@map("invoices")
}

model InvoiceItem {
  id         String   @id @default(uuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  qty        Int
  price      Decimal  @db.Decimal(18, 4)
  cost       Decimal  @db.Decimal(18, 4)
  total      Decimal  @db.Decimal(18, 4)
  expiryDate DateTime?
  note       String?
  category   String?
  createdAt  DateTime @default(now())

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model InventoryBatch {
  id                 String              @id @default(uuid())
  productId          String
  product            Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  batchNumber        String
  initialQty         Int
  stockQuantity      Int
  cost               Decimal             @db.Decimal(18, 4)
  expiryDate         DateTime?
  version            Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  reservations       Reservation[]
  tenantId           String?
  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@index([expiryDate])
  @@index([batchNumber])
  @@index([createdAt])
  @@map("inventory_batches")
}

model InventoryMovement {
  id            String          @id @default(uuid())
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  batchId       String?
  batch         InventoryBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  qty           Int // Positive for additions, negative for reductions
  type          MovementType
  referenceId   String? // Document ID triggering this
  referenceType String? // "INVOICE", "ADJUSTMENT", "TRANSFER"
  reason        String?
  previousStock Int
  currentStock  Int
  createdAt     DateTime        @default(now())
  branchId      String?
  tenantId      String?
  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([batchId])
  @@index([createdAt])
  @@index([branchId])
  @@map("inventory_movements")
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // "CREATE", "UPDATE", "DELETE", "POST_JOURNAL"
  entity     String // "Account", "Invoice", "Product"
  entityId   String
  before     String?  @db.Text // JSON string state
  after      String?  @db.Text // JSON string state
  ipAddress  String?
  requestId  String?
  createdAt  DateTime @default(now())
  branchId   String?

  @@index([timestamp])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([branchId])
  @@map("audit_logs")
}

model IdempotencyKey {
  id             String    @id @default(uuid())
  key            String    @unique
  requestHash    String
  endpoint       String
  requestMethod  String
  userId         String?
  responseBody   Json?
  responseStatus Int?
  processing     Boolean   @default(false)
  lockedAt       DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  @@index([key])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("idempotency_keys")
}

model SyncQueue {
  id         String     @id @default(uuid())
  syncStatus SyncStatus @default(PENDING)
  payload    Json
  entityType String
  entityId   String
  action     String
  attempts   Int        @default(0)
  lastError  String?    @db.Text
  version    Int        @default(1)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([syncStatus])
  @@index([createdAt])
  @@map("sync_queue")
}

model SyncEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique @default(uuid())
  sequence    BigInt   @unique @default(autoincrement())
  clientTime  DateTime
  serverTime  DateTime @default(now())
  userId      String?
  deviceId    String?
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  vectorClock Json?    // for vector-ready event ordering
  checksum    String?  // for data integrity check
  createdAt   DateTime @default(now())
  branchId    String?

  @@index([eventId])
  @@index([sequence])
  @@index([createdAt])
  @@index([branchId])
  @@map("sync_events")
}

model Reservation {
  id            String            @id @default(uuid())
  reservationId String            @unique @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  batchId       String?
  batch         InventoryBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  quantity      Int
  status        ReservationStatus @default(ACTIVE)
  userId        String?
  expiresAt     DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  branchId      String?

  @@index([reservationId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([branchId])
  @@map("reservations")
}

model Branch {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  location         String?
  phone            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  settings         BranchSettings?
  branchInventory  BranchInventory[]
  branchUsers      BranchUser[]
  transfersSource  BranchTransfer[]  @relation("SourceBranch")
  transfersTarget  BranchTransfer[]  @relation("TargetBranch")
  tenantId         String?
  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("branches")
}

model BranchSettings {
  id                    String   @id @default(uuid())
  branchId              String   @unique
  branch                Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  minStockLevelAlert    Boolean  @default(true)
  autoReorderTargetDays Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("branch_settings")
}

model BranchInventory {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId       String
  stockQuantity   Int      @default(0)
  reorderPoint    Int      @default(10)
  reorderQuantity Int      @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([branchId, productId])
  @@index([branchId])
  @@index([productId])
  @@map("branch_inventory")
}

model BranchTransfer {
  id             String               @id @default(uuid())
  transferNumber String               @unique
  sourceBranchId String
  sourceBranch   Branch               @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Restrict)
  targetBranchId String
  targetBranch   Branch               @relation("TargetBranch", fields: [targetBranchId], references: [id], onDelete: Restrict)
  status         String               @default("DRAFT") // DRAFT, APPROVED, IN_TRANSIT, RECEIVED, CANCELLED
  reason         String?
  createdBy      String?
  approvedBy     String?
  shippedBy      String?
  receivedBy     String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  items          BranchTransferItem[]
  tenantId       String?
  tenant         Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([sourceBranchId])
  @@index([targetBranchId])
  @@index([status])
  @@map("branch_transfers")
}

model BranchTransferItem {
  id         String         @id @default(uuid())
  transferId String
  transfer   BranchTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  qty        Int
  receivedQty Int?          @default(0)
  batchNumber String?
  expiryDate DateTime?
  createdAt  DateTime       @default(now())

  @@index([transferId])
  @@index([productId])
  @@map("branch_transfer_items")
}

model BranchUser {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, userId])
  @@index([branchId])
  @@index([userId])
  @@map("branch_users")
}

model Tenant {
  id                    String               @id @default(uuid())
  name                  String
  domain                String?              @unique
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  users                 TenantUser[]
  subscriptions         TenantSubscription[]
  licenses              License[]
  usageCounters         UsageCounter[]
  branches              Branch[]
  products              Product[]
  customers             Customer[]
  suppliers             Supplier[]
  invoices              Invoice[]
  accounts              Account[]
  journalEntries        JournalEntry[]
  branchTransfers       BranchTransfer[]
  inventoryMovements    InventoryMovement[]
  inventoryBatches      InventoryBatch[]

  @@map("tenants")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("TENANT_ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model SubscriptionPlan {
  id               String               @id @default(uuid())
  code             String               @unique // TRIAL, BASIC, BUSINESS, ENTERPRISE
  name             String
  price            Decimal              @db.Decimal(18, 4)
  durationDays     Int
  transactionLimit Int                  @default(-1) // -1 means unlimited, TRIAL has 200
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  subscriptions    TenantSubscription[]

  @@map("subscription_plans")
}

model TenantSubscription {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  startDate DateTime         @default(now())
  endDate   DateTime
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("tenant_subscriptions")
}

model License {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenseKey String   @unique
  isActive   Boolean  @default(true)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("licenses")
}

model UsageCounter {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionCount Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([tenantId])
  @@map("usage_counters")
}

model CrashLog {
  id                String   @id @default(uuid())
  tenantId          String?
  branchId          String?
  userId            String?
  route             String
  deviceFingerprint String?
  appVersion        String?
  stackTrace        String?  @db.Text
  errorMessage      String   @db.Text
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([tenantId])
  @@index([branchId])
  @@map("crash_logs")
}

model DeviceRegistration {
  deviceId       String   @id
  tenantId       String
  branchId       String
  deviceName     String
  androidVersion String?
  appVersion     String?
  lastSync       DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([branchId])
  @@map("device_registrations")
}

model AiUsageLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String
  model         String
  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  estimatedCost Float    @default(0.0)
  timestamp     DateTime @default(now())

  @@index([timestamp])
  @@index([tenantId])
  @@index([userId])
  @@map("ai_usage_logs")
}





