{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*",
        "./*"
      ],
      "@/services/*": [
        "./services/*"
      ],
      "@/repositories/*": [
        "./repositories/*"
      ],
      "@/core/engines/*": [
        "./src/core/engines/*"
      ],
      "@/store/*": [
        "./store/*"
      ],
      "@/hooks/*": [
        "./src/core/engines/hooks/*"
      ],
      "@/types": [
        "./types.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}