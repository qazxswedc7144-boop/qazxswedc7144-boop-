    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "chart.js": "4.4.1",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.2.1",
    "dexie": "3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.13.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
