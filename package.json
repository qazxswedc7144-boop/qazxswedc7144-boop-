    "react-chartjs-2": "5.2.0",
    "react-dom": "18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.0",
    "react-window": "1.8.10",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "tesseract.js": "^7.0.0",
